{
  "name": "xml-language-server",
  "version": "1.0.0",
  "description": "LSP wrapper for xml-language-service",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.js \"--banner:js=const _fileUrl=require('url').pathToFileURL(__filename).href;\" --define:import.meta.url=_fileUrl && cp node_modules/xml-language-service/dist/xerces-wasm/xerces_validator.wasm dist/xerces_validator.wasm",
    "bundle": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=dist/server.js \"--banner:js=const _fileUrl=require('url').pathToFileURL(__filename).href;\" --define:import.meta.url=_fileUrl && cp node_modules/xml-language-service/dist/xerces-wasm/xerces_validator.wasm dist/xerces_validator.wasm && cp -r resources dist/resources",
    "build:watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "xml-language-service": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
